# Pegue esses valores em: app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=SUA_CHAVE_ANON_PUBLISHABLE

# Só usada pelo cron de prospecção (app/api/prospect/run) e pelo script
# scripts/seed-user.mjs. É a "service_role" key — NUNCA a anon. Ignora RLS,
# então só entra como variável de ambiente do servidor, nunca no navegador.
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# Gerada por você (ex: openssl rand -hex 32). Protege a rota do cron —
# a Vercel envia esse valor automaticamente como Authorization: Bearer quando
# invoca o cron, então basta cadastrar essa variável no projeto da Vercel.
CRON_SECRET=uma-string-aleatoria-de-pelo-menos-16-caracteres

# A API key da Groq NÃO fica aqui — cada usuário loga e cola a própria
# em ⚙ Configurações → Motor. Ela é salva no Supabase (tabela app_settings),
# nunca em variável de ambiente. O mesmo vale pra chave do Google Places
# (⚙ → Prospecção).
